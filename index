<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cummings Electrical — Client Risk Monitor</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: #0b1120;
    color: #e2e8f0;
    min-height: 100vh;
    font-size: 15px;
    line-height: 1.6;
  }

  a { color: inherit; text-decoration: none; }

  .header {
    background: linear-gradient(135deg, #0f1629 0%, #162040 100%);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding: 32px 44px 24px;
  }

  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .header h1 {
    font-size: 24px;
    font-weight: 700;
    color: #f1f5f9;
    letter-spacing: -0.3px;
  }

  .header .subtitle {
    font-size: 14px;
    color: #94a3b8;
    margin-top: 4px;
  }

  .header .date-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #cbd5e1;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 7px 16px;
    border-radius: 8px;
  }

  .container { padding: 28px 44px 48px; }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }

  .company-card {
    background: #131b2e;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.07);
    overflow: hidden;
  }

  .card-header {
    padding: 22px 28px 18px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .card-header .ticker {
    font-family: 'JetBrains Mono', monospace;
    font-size: 22px;
    font-weight: 700;
    color: #f1f5f9;
  }

  .card-header .company-name {
    font-size: 14px;
    color: #94a3b8;
    margin-top: 3px;
  }

  .risk-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    padding: 6px 16px;
    border-radius: 20px;
    letter-spacing: 0.6px;
    text-transform: uppercase;
  }

  .risk-critical {
    background: rgba(239, 68, 68, 0.15);
    color: #fca5a5;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }

  .risk-high {
    background: rgba(251, 146, 60, 0.15);
    color: #fdba74;
    border: 1px solid rgba(251, 146, 60, 0.3);
  }

  /* ===== TOGGLE BUTTONS ===== */
  .toggle-bar {
    display: flex;
    padding: 14px 20px;
    gap: 12px;
    background: rgba(0,0,0,0.25);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }

  .toggle-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 18px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 2px solid transparent;
    user-select: none;
  }

  .toggle-btn .icon { font-size: 16px; }

  .toggle-btn.good-btn {
    background: rgba(52, 211, 153, 0.06);
    color: #6b7280;
    border-color: rgba(52, 211, 153, 0.12);
  }
  .toggle-btn.good-btn:hover {
    background: rgba(52, 211, 153, 0.1);
    color: #94a3b8;
  }
  .toggle-btn.good-btn.active {
    background: rgba(52, 211, 153, 0.15);
    color: #34d399;
    border-color: #34d399;
    box-shadow: 0 0 20px rgba(52, 211, 153, 0.12);
  }

  .toggle-btn.bad-btn {
    background: rgba(248, 113, 113, 0.06);
    color: #6b7280;
    border-color: rgba(248, 113, 113, 0.12);
  }
  .toggle-btn.bad-btn:hover {
    background: rgba(248, 113, 113, 0.1);
    color: #94a3b8;
  }
  .toggle-btn.bad-btn.active {
    background: rgba(248, 113, 113, 0.15);
    color: #f87171;
    border-color: #f87171;
    box-shadow: 0 0 20px rgba(248, 113, 113, 0.12);
  }

  .toggle-btn .count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 6px;
    background: rgba(255,255,255,0.08);
  }
  .toggle-btn.good-btn.active .count { background: rgba(52,211,153,0.2); }
  .toggle-btn.bad-btn.active .count { background: rgba(248,113,113,0.2); }

  /* ===== NEWS PANELS ===== */
  .news-panel {
    padding: 16px 20px 24px;
    display: none;
  }
  .news-panel.active { display: block; }

  .news-item {
    display: block;
    padding: 18px 20px;
    margin-bottom: 12px;
    border-radius: 12px;
    border-left: 4px solid;
    transition: all 0.15s ease;
    cursor: pointer;
  }

  .news-item:hover { transform: translateX(3px); }

  .news-item.good {
    border-left-color: #34d399;
    background: rgba(52, 211, 153, 0.04);
  }
  .news-item.good:hover { background: rgba(52, 211, 153, 0.08); }

  .news-item.bad {
    border-left-color: #f87171;
    background: rgba(248, 113, 113, 0.04);
  }
  .news-item.bad:hover { background: rgba(248, 113, 113, 0.08); }

  .news-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }

  .news-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .impact-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 5px;
    letter-spacing: 0.4px;
  }

  .impact-tag.positive { background: rgba(52, 211, 153, 0.12); color: #6ee7b7; }
  .impact-tag.negative { background: rgba(248, 113, 113, 0.12); color: #fca5a5; }
  .impact-tag.caution  { background: rgba(251, 191, 36, 0.12); color: #fde68a; }

  .news-title {
    font-size: 16px;
    font-weight: 600;
    color: #f1f5f9;
    line-height: 1.45;
    margin-bottom: 8px;
  }

  .news-impact {
    font-size: 14.5px;
    color: #cbd5e1;
    line-height: 1.65;
  }

  .source-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 12.5px;
    color: #60a5fa;
    margin-top: 10px;
    opacity: 0.8;
    transition: opacity 0.15s;
  }
  .news-item:hover .source-link { opacity: 1; text-decoration: underline; }
  .source-link svg {
    width: 13px; height: 13px;
    fill: none; stroke: currentColor; stroke-width: 2;
  }

  /* ===== SUMMARY STRIP ===== */
  .summary-strip {
    margin-top: 28px;
    background: #131b2e;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.07);
    padding: 22px 32px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 24px;
  }

  .summary-item { text-align: center; }

  .summary-item .label {
    font-size: 12px;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }

  .summary-item .value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 20px;
    font-weight: 700;
  }

  .summary-item .value.red    { color: #fca5a5; }
  .summary-item .value.orange { color: #fdba74; }
  .summary-item .value.yellow { color: #fde68a; }

  .footer-note {
    margin-top: 24px;
    text-align: center;
    font-size: 12px;
    color: #475569;
  }

  @media (max-width: 960px) {
    .grid { grid-template-columns: 1fr; }
    .summary-strip { grid-template-columns: 1fr 1fr; }
    .container { padding: 20px 16px; }
    .header { padding: 24px 16px; }
  }
</style>
</head>
